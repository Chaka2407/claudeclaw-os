# Agent configuration
# Copy this folder, rename it, and fill in your values.
#
# Then add your bot token to .env:
#   MYAGENT_BOT_TOKEN=1234567890:AAFxxxxxxx
#
# Start with:
#   npm start -- --agent myagent

name: My Agent
description: What this agent does

# The env var name in .env that holds this agent's Telegram bot token.
# Create a bot via @BotFather in Telegram, paste the token into .env.
telegram_bot_token_env: MYAGENT_BOT_TOKEN

# Provider backend. OpenCode uses its own configured default model.
# For Claude, use:
# provider:
#   type: claude
#   model: claude-sonnet-4-6
provider:
  type: opencode

# MCP server allowlist (optional).
# List server names defined in ~/.claude/settings.json or .claude/settings.json.
# Both stdio (command/args/env) and HTTP/SSE (type/url/headers) servers are supported.
# If omitted, the agent gets all configured servers. If set, only the listed ones.
# mcp_servers:
#   - open-brain
#   - session-tracker
#   - slack

# Obsidian integration (optional).
# Assign folders from your vault so this agent auto-loads relevant context.
# obsidian:
#   vault: /path/to/your/obsidian/vault
#   folders:
#     - FolderA/
#     - FolderB/
#   read_only:
#     - Daily Notes/
